FROM python:3.12-slim

# Install docker-cli just in case we need it for debugging
RUN apt-get update && apt-get install -y docker.io && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install uv

COPY pyproject.toml .
RUN uv sync --no-dev

COPY app/ app/
COPY worker.py .

CMD ["sh", "-c", "uv run rq worker judge --with-scheduler --url $REDIS_URL"]
