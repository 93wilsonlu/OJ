# Production deployment template.
# Copy this file to .env on the deployment VM and replace every placeholder.

# Security
SECRET_KEY=replace-with-a-long-random-production-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Initial administrator account.
# Do not use demo credentials on a public deployment.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_NAME=System Admin

# Docker Compose VM deployment defaults.
# If moving to Cloud SQL or Memorystore, replace these URLs with the managed
# service connection strings.
DATABASE_URL=postgresql+asyncpg://oj:oj@postgres:5432/oj
REDIS_URL=redis://redis:6379/0

# Object storage.
# Current VM demo uses MinIO. Future production can replace this with a storage
# adapter backed by Cloud Storage.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_BUCKET=oj-storage
MINIO_SECURE=false

# Judge worker reliability.
STUCK_SUBMISSION_SECONDS=300
WORKER_HEARTBEAT_INTERVAL_SECONDS=15

