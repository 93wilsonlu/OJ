# Production deployment template.
# Copy this file to .env on the deployment VM and replace every placeholder.

# Security
SECRET_KEY=replace-with-a-long-random-production-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Initial administrator account.
# Do not use demo credentials on a public deployment.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_NAME=System Admin

# Docker Compose VM deployment defaults.
# If moving to Cloud SQL, replace this URL with the managed service connection string.
DATABASE_URL=postgresql+asyncpg://oj:oj@postgres:5432/oj

# GCP object storage and queue.
GCS_BUCKET=replace-with-gcs-bucket
GCS_PROJECT=replace-with-gcp-project
PUBSUB_JUDGE_TOPIC=projects/replace-with-gcp-project/topics/judge-submissions
PUBSUB_RUN_TOPIC=projects/replace-with-gcp-project/topics/judge-runs
PUBSUB_JUDGE_SUBSCRIPTION=projects/replace-with-gcp-project/subscriptions/judge-submissions-sub
PUBSUB_RUN_SUBSCRIPTION=projects/replace-with-gcp-project/subscriptions/judge-runs-sub

# Judge worker reliability.
STUCK_SUBMISSION_SECONDS=300
WORKER_ID=worker-vm-1
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
